{
  "version": 2,
  "public": true,
  "env": {
    "FIREBASE_SERVICE_ACCOUNT": {
      "description": "Firebase Admin SDK service account JSON (stringified)",
      "required": true
    },
    "FIREBASE_PROJECT_ID": {
      "description": "Firebase project ID",
      "required": true
    }
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        }
      ]
    }
  ]
}
